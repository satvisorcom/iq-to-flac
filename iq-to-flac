#!/bin/bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: iq-to-flac [OPTIONS] INPUT OUTPUT

Encode raw IQ samples to FLAC (non-audio mode, sample rate 0).

Options:
  --bps N            Bits per sample: 8, 16 (default), or 32
  --sample-rate HZ   IQ sample rate, stored as vorbis comment
  --frequency HZ     Center frequency, stored as vorbis comment
  --compression N    FLAC compression level 0-8 (default: 5)
  -h, --help         Show this help

Input is raw interleaved IQ (I,Q,I,Q,...), signed, little-endian.
EOF
    exit "${1:-0}"
}

bps=16
sample_rate=""
frequency=""
compression=5
positional=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --bps)         bps="$2"; shift 2 ;;
        --sample-rate) sample_rate="$2"; shift 2 ;;
        --frequency)   frequency="$2"; shift 2 ;;
        --compression) compression="$2"; shift 2 ;;
        -h|--help)     usage 0 ;;
        -*)            echo "Unknown option: $1" >&2; usage 1 ;;
        *)             positional+=("$1"); shift ;;
    esac
done

if [[ ${#positional[@]} -ne 2 ]]; then
    echo "Error: expected INPUT and OUTPUT arguments" >&2
    usage 1
fi

input="${positional[0]}"
output="${positional[1]}"

case "$bps" in
    8|16|32) ;;
    *) echo "Error: --bps must be 8, 16, or 32" >&2; exit 1 ;;
esac

flac --force-raw-format \
    --channels=2 \
    --bps="$bps" \
    --endian=little \
    --sign=signed \
    --sample-rate=0 \
    --compression-level-"$compression" \
    -o "$output" \
    "$input"

# Add IQ metadata as vorbis comments
if [[ -n "$sample_rate" ]]; then
    metaflac --set-tag="IQ_SAMPLE_RATE=$sample_rate" "$output"
fi
if [[ -n "$frequency" ]]; then
    metaflac --set-tag="FREQUENCY=$frequency" "$output"
fi
metaflac --set-tag="IQ_BITS_PER_SAMPLE=$bps" "$output"
